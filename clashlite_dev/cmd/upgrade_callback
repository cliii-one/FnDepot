#!/bin/bash
set -euo pipefail

if [ -f "${TRIM_PKGVAR}/.config_dir" ]; then
    cp "${TRIM_PKGVAR}/.config_dir" "${TRIM_PKGVAR}/.config_dir_prev"
fi

if [ -n "${TRIM_DATA_SHARE_PATHS:-}" ]; then
    SHARE_DIR=$(echo "${TRIM_DATA_SHARE_PATHS}" | cut -d: -f1)
    if [ -n "${SHARE_DIR}" ] && [ -f "${SHARE_DIR}/config.yaml" ]; then
        echo "配置文件已存在，保留: ${SHARE_DIR}/config.yaml"
    fi
fi

exit 0
