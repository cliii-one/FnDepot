#!/bin/bash
set -euo pipefail

NODE_BIN="${TRIM_APPDEST}/server/node"
SUBSTORE_JS="${TRIM_APPDEST}/server/sub-store.min.js"
DATA_DIR="${TRIM_PKGVAR}"
LOG_FILE="${TRIM_PKGVAR}/substore.log"
PID_FILE="${TRIM_PKGVAR}/substore.pid"
PROXY_PID_FILE="${TRIM_PKGVAR}/gateway-proxy.pid"
CONFIG_FILE="${TRIM_PKGVAR}/config.json"
GATEWAY_PROXY_BIN="${TRIM_APPDEST}/server/gateway-proxy"

API_PATH="/api"
if [ -f "${CONFIG_FILE}" ]; then
    _p=$(cat "${CONFIG_FILE}" 2>/dev/null | grep -o '"api_path"[[:space:]]*:[[:space:]]*"[^"]*"' | sed 's/.*"api_path"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')
    [ -n "$_p" ] && API_PATH="$_p"
fi
case "$API_PATH" in /*) ;; *) API_PATH="/$API_PATH" ;; esac
API_PATH="${API_PATH%/}"

export SUB_STORE_DATA_BASE_PATH="${DATA_DIR}"
export SUB_STORE_BACKEND_API_PORT="8001"
export SUB_STORE_BACKEND_API_HOST="127.0.0.1"
export SUB_STORE_BACKEND_MERGE="true"
export SUB_STORE_FRONTEND_PATH="${TRIM_APPDEST}/www"
export SUB_STORE_FRONTEND_BACKEND_PATH="${API_PATH}"
export SUB_STORE_X_POWERED_BY="Sub-Store"
export SUB_STORE_BODY_JSON_LIMIT="10mb"
export NODE_NO_WARNINGS=1

ensure_dirs() {
    mkdir -p "${DATA_DIR}"
    [ -f "${DATA_DIR}/sub-store.json" ] || echo '{}' > "${DATA_DIR}/sub-store.json"
    [ -f "${DATA_DIR}/root.json" ] || echo '{}' > "${DATA_DIR}/root.json"
    chown -R "${TRIM_USERNAME:-substore}:${TRIM_GROUPNAME:-substore}" "${DATA_DIR}" 2>/dev/null || true
}

start_substore() {
    if check_substore_status; then
        return 0
    fi

    ensure_dirs

    if [ ! -x "${NODE_BIN}" ]; then
        echo "Node.js 运行时未找到: ${NODE_BIN}" > "${TRIM_TEMP_LOGFILE}" 2>/dev/null
        return 1
    fi

    if [ ! -f "${SUBSTORE_JS}" ]; then
        echo "Sub-Store 后端脚本未找到: ${SUBSTORE_JS}" > "${TRIM_TEMP_LOGFILE}" 2>/dev/null
        return 1
    fi

    cd "${TRIM_APPDEST}/server"

    exec -a "SubStore" "${NODE_BIN}" \
        "${SUBSTORE_JS}" \
        >> "${LOG_FILE}" 2>&1 &

    printf "%s" "$!" > "${PID_FILE}"

    local count=0
    while [ ${count} -lt 10 ]; do
        if curl -s http://127.0.0.1:8001 > /dev/null 2>&1; then
            return 0
        fi
        sleep 1
        count=$((count + 1))
    done
    return 0
}

start_gateway_proxy() {
    if check_proxy_status; then
        return 0
    fi

    if [ ! -x "${GATEWAY_PROXY_BIN}" ]; then
        echo "网关反向代理程序未找到: ${GATEWAY_PROXY_BIN}" > "${TRIM_TEMP_LOGFILE}" 2>/dev/null
        return 1
    fi

    "${GATEWAY_PROXY_BIN}" >> "${LOG_FILE}" 2>&1 &
    printf "%s" "$!" > "${PROXY_PID_FILE}"

    local socket_path="${TRIM_APPDEST}/substore.sock"
    local count=0
    while [ ${count} -lt 5 ]; do
        if [ -S "${socket_path}" ]; then
            return 0
        fi
        sleep 1
        count=$((count + 1))
    done
    return 0
}

stop_substore() {
    if [ -r "${PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')

        if kill -0 "${pid}" 2>/dev/null; then
            kill -TERM ${pid} >> ${LOG_FILE} 2>&1

            local count=0
            while kill -0 "${pid}" 2>/dev/null && [ ${count} -lt 10 ]; do
                sleep 1
                count=$((count + 1))
            done

            if kill -0 "${pid}" 2>/dev/null; then
                kill -KILL ${pid}
            fi
        fi
        rm -f "${PID_FILE}"
    fi

    pkill -f "node.*sub-store.min.js" 2>/dev/null || true
    return 0
}

stop_gateway_proxy() {
    if [ -r "${PROXY_PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${PROXY_PID_FILE}" | tr -d '[:space:]')

        if kill -0 "${pid}" 2>/dev/null; then
            kill -TERM ${pid} 2>/dev/null || true

            local count=0
            while kill -0 "${pid}" 2>/dev/null && [ ${count} -lt 5 ]; do
                sleep 1
                count=$((count + 1))
            done

            if kill -0 "${pid}" 2>/dev/null; then
                kill -KILL ${pid} 2>/dev/null || true
            fi
        fi
        rm -f "${PROXY_PID_FILE}"
    fi

    rm -f "${TRIM_APPDEST}/substore.sock"
    return 0
}

check_substore_status() {
    if [ -f "${PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if kill -0 "${pid}" 2>/dev/null; then
            return 0
        else
            rm -f "${PID_FILE}"
        fi
    fi
    return 1
}

check_proxy_status() {
    if [ -f "${PROXY_PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${PROXY_PID_FILE}" | tr -d '[:space:]')
        if kill -0 "${pid}" 2>/dev/null; then
            return 0
        else
            rm -f "${PROXY_PID_FILE}"
        fi
    fi
    return 1
}

case $1 in
start)
    start_substore
    start_gateway_proxy
    ;;
stop)
    stop_gateway_proxy
    stop_substore
    ;;
status)
    if check_substore_status && check_proxy_status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
