#!/bin/bash
# ClashLite fnOS 生命周期脚本

mkdir -p "${TRIM_PKGVAR}" 2>/dev/null || true

LOG_FILE="${TRIM_PKGVAR}/info.log"
MAX_LOG_SIZE=102400  # 100KB 轮转

log() {
    # 日志超过 100KB 时轮转
    [ -f "${LOG_FILE}" ] && [ "$(stat -f%z "${LOG_FILE}" 2>/dev/null || stat -c%s "${LOG_FILE}" 2>/dev/null || echo 0)" -gt "${MAX_LOG_SIZE}" ] 2>/dev/null && mv "${LOG_FILE}" "${LOG_FILE}.old" 2>/dev/null || true
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}" 2>/dev/null || true
}

err() {
    echo "$1" > "${TRIM_TEMP_LOGFILE}" 2>/dev/null || true
    log "ERROR: $1"
}

# ── 路径 ──
MIHOMO_DIR="${TRIM_PKGHOME}/mihomo"
MIHOMO_BIN="${MIHOMO_DIR}/mihomo"
MIHOMO_SOCKET="${TRIM_APPDEST}/mihomo.sock"
CLASHLITE_SOCK="${TRIM_APPDEST}/clashlite.sock"
PROXY_BIN="${TRIM_APPDEST}/server/clashlite"
MIHOMO_CONFIG="${MIHOMO_DIR}/config.yaml"

if [ -n "${TRIM_DATA_SHARE_PATHS:-}" ]; then
    SHARE_DIR="${TRIM_DATA_SHARE_PATHS%%:*}"
    [ -f "${SHARE_DIR}/config.yaml" ] && MIHOMO_CONFIG="${SHARE_DIR}/config.yaml"
fi

# ── 修复占位符 ──
fix_socket() {
    if grep -q "MIHOMO_UNIX_SOCKET" "$1" 2>/dev/null; then
        sed -i "s|MIHOMO_UNIX_SOCKET|${MIHOMO_SOCKET}|g" "$1"
    fi
}

# ── 从模板创建配置 ──
ensure_config() {
    [ -f "${MIHOMO_CONFIG}" ] && { fix_socket "${MIHOMO_CONFIG}"; return 0; }
    local tmpl="${TRIM_APPDEST}/server/config/OneSmart.yaml"
    [ ! -f "${tmpl}" ] && return 0
    mkdir -p "$(dirname "${MIHOMO_CONFIG}")" 2>/dev/null || true
    cp "${tmpl}" "${MIHOMO_CONFIG}"
    sed -i "s/MB_SECRET/${wizard_secret:-yyds666}/g" "${MIHOMO_CONFIG}"
    sed -i "s|AIRPORT_URL1|${wizard_provider_url_1:-https://example.com}|g" "${MIHOMO_CONFIG}"
    fix_socket "${MIHOMO_CONFIG}"
}

copy_bundled() {
    local src="${TRIM_APPDEST}/server/data/mihomo"
    [ ! -d "${src}" ] && return 0
    mkdir -p "${MIHOMO_DIR}" 2>/dev/null || true
    [ -f "${src}/mihomo" ] && cp -f "${src}/mihomo" "${MIHOMO_BIN}" && chmod +x "${MIHOMO_BIN}"
    for f in Model.bin geoip.metadb geosite.dat ASN.mmdb; do
        [ -f "${src}/${f}" ] && [ ! -f "${MIHOMO_DIR}/${f}" ] && cp "${src}/${f}" "${MIHOMO_DIR}/${f}"
    done
}

copy_ui() {
    local src="${TRIM_APPDEST}/server/public"
    local dst="${MIHOMO_DIR}/ui"
    [ ! -d "${src}" ] || [ -d "${dst}" ] && return 0
    cp -r "${src}" "${dst}" 2>/dev/null || true
}

is_running() {
    [ -f "$1" ] || return 1
    local pid
    pid=$(cat "$1" | tr -d '[:space:]')
    [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null && return 0
    rm -f "$1"
    return 1
}

start_mihomo() {
    is_running "${TRIM_PKGVAR}/mihomo.pid" && return 0
    copy_bundled
    copy_ui
    ensure_config

    if [ ! -x "${MIHOMO_BIN}" ]; then
        err "未找到 mihomo 核心程序文件，请卸载后重新安装"
        return 1
    fi

    rm -f "${MIHOMO_SOCKET}" 2>/dev/null || true

    local args=(-d "${MIHOMO_DIR}")
    [ "${MIHOMO_CONFIG}" != "${MIHOMO_DIR}/config.yaml" ] && args+=(-f "${MIHOMO_CONFIG}")

    "${MIHOMO_BIN}" "${args[@]}" >> "${LOG_FILE}" 2>&1 &
    local pid=$!
    echo "${pid}" > "${TRIM_PKGVAR}/mihomo.pid"
    log "mihomo started PID=${pid}"

    local i
    for i in $(seq 1 15); do
        [ -S "${MIHOMO_SOCKET}" ] && return 0
        sleep 1
    done

    err "mihomo 启动超时：Unix Socket 未就绪"
    return 1
}

start_proxy() {
    is_running "${TRIM_PKGVAR}/clashlite.pid" && return 0

    if [ ! -x "${PROXY_BIN}" ]; then
        err "未找到 clashlite 网关程序，请卸载后重新安装"
        return 1
    fi

    "${PROXY_BIN}" >> "${LOG_FILE}" 2>&1 &
    local pid=$!
    echo "${pid}" > "${TRIM_PKGVAR}/clashlite.pid"
    log "clashlite started PID=${pid}"

    local i
    for i in $(seq 1 5); do
        [ -S "${CLASHLITE_SOCK}" ] && return 0
        sleep 1
    done

    err "clashlite 启动超时：Unix Socket 未就绪"
    return 1
}

stop_mihomo() {
    if [ -f "${TRIM_PKGVAR}/mihomo.pid" ]; then
        local pid
        pid=$(cat "${TRIM_PKGVAR}/mihomo.pid" | tr -d '[:space:]')
        [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null && kill -TERM "${pid}" 2>/dev/null
        rm -f "${TRIM_PKGVAR}/mihomo.pid"
    fi
    sleep 2
    pkill -f "mihomo" 2>/dev/null || true
    rm -f "${MIHOMO_SOCKET}" 2>/dev/null || true
    log "mihomo stopped"
}

stop_proxy() {
    if [ -f "${TRIM_PKGVAR}/clashlite.pid" ]; then
        local pid
        pid=$(cat "${TRIM_PKGVAR}/clashlite.pid" | tr -d '[:space:]')
        [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null && kill -TERM "${pid}" 2>/dev/null
        rm -f "${TRIM_PKGVAR}/clashlite.pid"
    fi
    sleep 1
    pkill -f "${PROXY_BIN}" 2>/dev/null || true
    rm -f "${CLASHLITE_SOCK}" 2>/dev/null || true
    log "clashlite stopped"
}

case "${1:-}" in
start)
    mkdir -p "${TRIM_PKGVAR}" 2>/dev/null || true
    start_mihomo
    start_proxy
    ;;
stop)
    stop_proxy
    stop_mihomo
    ;;
status)
    is_running "${TRIM_PKGVAR}/mihomo.pid" && is_running "${TRIM_PKGVAR}/clashlite.pid" && exit 0
    exit 3
    ;;
*)
    echo "Usage: $0 {start|stop|status}" >&2
    exit 1
    ;;
esac
