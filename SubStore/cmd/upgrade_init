#!/bin/bash
# ============================================================
# SubStore for fnOS - 升级前备份 (upgrade_init)
# ============================================================
# 执行时机：新版 fpk 解压之前
# 用途：备份用户数据，防止升级覆盖导致数据丢失
# ============================================================

DATA_DIR="${TRIM_PKGVAR}"
BACKUP_DIR="${TRIM_PKGVAR}/.backup_upgrade"

# ---- 备份所有 JSON 数据文件 ----
mkdir -p "${BACKUP_DIR}"
find "${DATA_DIR}" -maxdepth 1 -name "*.json" -exec cp -f {} "${BACKUP_DIR}/" \; 2>/dev/null || true

# ---- 停止当前运行的服务 ----
PID_FILE="${TRIM_PKGVAR}/substore.pid"
LOG_FILE="${TRIM_PKGVAR}/substore.log"

if [ -r "${PID_FILE}" ]; then
    pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
    if kill -0 "${pid}" 2>/dev/null; then
        kill -TERM "${pid}" >> ${LOG_FILE} 2>&1
        sleep 2
        kill -KILL "${pid}" 2>/dev/null || true
    fi
    rm -f "${PID_FILE}"
fi

pkill -f "node.*sub-store.min.js" 2>/dev/null || true

exit 0
