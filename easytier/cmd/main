#!/bin/bash
set -euo pipefail

EASYTIER_DIR="${TRIM_PKGHOME}/easytier"
CORE_PID_FILE="${TRIM_PKGVAR}/easytier-core.pid"
WEB_PID_FILE="${TRIM_PKGVAR}/easytier-web.pid"
LOG_FILE="${TRIM_PKGVAR}/info.log"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "${LOG_FILE}"
}

# 将打包的二进制复制到可写目录，并赋予执行权限
copy_bundled() {
    local bundled_dir="${TRIM_APPDEST}/server/data/easytier"
    if [ -d "${bundled_dir}" ]; then
        mkdir -p "${EASYTIER_DIR}"
        for f in easytier-core easytier-web-embed easytier-cli; do
            if [ -f "${bundled_dir}/${f}" ]; then
                cp -f "${bundled_dir}/${f}" "${EASYTIER_DIR}/${f}" 2>/dev/null && chmod +x "${EASYTIER_DIR}/${f}"
            fi
        done
    fi
}

# 启动 easytier-core，仅开启配置服务端口，不传任何网络参数
# 用户通过 Web 前端自行配置网络
start_core() {
    if check_core_status; then
        return 0
    fi

    copy_bundled

    if [ ! -x "${EASYTIER_DIR}/easytier-core" ]; then
        log_msg "ERROR: easytier-core binary not found"
        echo "【启动异常】未找到 EasyTier 核心程序文件。" > "${TRIM_TEMP_LOGFILE}"
        echo "请尝试在飞牛应用中心卸载后重新安装此应用。" >> "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi

    # 仅开启配置服务端口，等待 Web 前端下发配置
    local args=()
    args+=("-w" "udp://127.0.0.1:22020/admin")

    log_msg "Starting easytier-core with args: ${args[*]}"

    export ET_STATE_DIR="${TRIM_PKGVAR}"
    cd "${TRIM_PKGVAR}"
    "${EASYTIER_DIR}/easytier-core" "${args[@]}" >> "${LOG_FILE}" 2>&1 &
    local pid=$!
    printf "%s" "${pid}" > "${CORE_PID_FILE}"
    log_msg "easytier-core started with PID ${pid}"

    local count=0
    while [ ${count} -lt 10 ]; do
        if kill -0 "${pid}" 2>/dev/null; then
            log_msg "easytier-core is running"
            return 0
        fi
        sleep 1
        count=$((count + 1))
    done
    log_msg "WARNING: easytier-core may not have started properly"
    return 0
}

# 启动 easytier-web-embed Web 控制台
start_web() {
    if check_web_status; then
        return 0
    fi

    if [ ! -x "${EASYTIER_DIR}/easytier-web-embed" ]; then
        log_msg "WARNING: easytier-web-embed not found, skipping web console"
        return 0
    fi

    log_msg "Starting easytier-web-embed ..."

    export ET_STATE_DIR="${TRIM_PKGVAR}"
    export ET_WEB_DB="${TRIM_PKGVAR}/et.db"
    cd "${TRIM_PKGVAR}"
    "${EASYTIER_DIR}/easytier-web-embed" \
        --db "${TRIM_PKGVAR}/et.db" \
        --api-server-port 11211 \
        --config-server-port 22020 \
        --config-server-protocol udp \
        >> "${LOG_FILE}" 2>&1 &
    local pid=$!
    printf "%s" "${pid}" > "${WEB_PID_FILE}"
    log_msg "easytier-web-embed started with PID ${pid}"

    local count=0
    while [ ${count} -lt 5 ]; do
        if kill -0 "${pid}" 2>/dev/null; then
            log_msg "easytier-web-embed is running"
            return 0
        fi
        sleep 1
        count=$((count + 1))
    done
    log_msg "WARNING: easytier-web-embed may not have started properly"
    return 0
}

stop_core() {
    log_msg "Stopping easytier-core ..."
    if [ -r "${CORE_PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${CORE_PID_FILE}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            kill -TERM "${pid}" 2>/dev/null || true
            local count=0
            while kill -0 "${pid}" 2>/dev/null && [ ${count} -lt 10 ]; do
                sleep 1
                count=$((count + 1))
            done
            if kill -0 "${pid}" 2>/dev/null; then
                kill -KILL "${pid}" 2>/dev/null || true
            fi
        fi
        rm -f "${CORE_PID_FILE}"
    fi

    local core_pid
    core_pid=$(pgrep -f "easytier-core" 2>/dev/null) || true
    if [ -n "${core_pid}" ]; then
        kill -TERM ${core_pid} 2>/dev/null || true
        sleep 2
    fi
    return 0
}

stop_web() {
    log_msg "Stopping easytier-web-embed ..."
    if [ -r "${WEB_PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${WEB_PID_FILE}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            kill -TERM "${pid}" 2>/dev/null || true
            local count=0
            while kill -0 "${pid}" 2>/dev/null && [ ${count} -lt 5 ]; do
                sleep 1
                count=$((count + 1))
            done
            if kill -0 "${pid}" 2>/dev/null; then
                kill -KILL "${pid}" 2>/dev/null || true
            fi
        fi
        rm -f "${WEB_PID_FILE}"
    fi

    local web_pid
    web_pid=$(pgrep -f "easytier-web-embed" 2>/dev/null) || true
    if [ -n "${web_pid}" ]; then
        kill -TERM ${web_pid} 2>/dev/null || true
        sleep 1
    fi
    return 0
}

check_core_status() {
    if [ -f "${CORE_PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${CORE_PID_FILE}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            return 0
        else
            rm -f "${CORE_PID_FILE}"
        fi
    fi
    return 1
}

check_web_status() {
    if [ -f "${WEB_PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${WEB_PID_FILE}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            return 0
        else
            rm -f "${WEB_PID_FILE}"
        fi
    fi
    return 1
}

case "${1:-}" in
start)
    mkdir -p "${TRIM_PKGVAR}"
    start_core
    start_web
    ;;
stop)
    stop_web
    stop_core
    ;;
status)
    if check_core_status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    echo "Usage: $0 {start|stop|status}" >&2
    exit 1
    ;;
esac
