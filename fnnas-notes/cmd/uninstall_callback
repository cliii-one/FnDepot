#!/bin/bash
# ============================================================
# 贴贴密笺 - 卸载完成回调脚本
# ============================================================
# 执行时机: 应用文件删除后
# 注意: 系统默认会保留应用数据目录；如用户选择删除数据，
#       数据清理已在 uninstall_init 中完成，此处仅输出最终状态。
# ============================================================

# 根据用户选择处理数据
# wizard_data_action 环境变量由卸载向导设置
# keep: 保留数据（默认）
# delete: 删除所有数据
DATA_ACTION="${wizard_data_action:-keep}"

if [ "$DATA_ACTION" = "delete" ]; then
    echo "已删除所有应用数据"
else
    echo "已保留应用数据，将来重新安装时可恢复"
fi

echo "贴贴密笺卸载完成"
exit 0
