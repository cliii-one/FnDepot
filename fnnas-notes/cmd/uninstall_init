#!/bin/bash
# ============================================================
# 贴贴密笺 - 卸载初始化脚本
# ============================================================
# 执行时机: 应用文件删除前
# 用途: 停止应用运行、根据用户选择处理数据
# ============================================================

APP_DIR="${TRIM_APPDEST}"
DATA_DIR="${TRIM_PKGVAR}/data"

PID_FILE="${TRIM_PKGVAR}/app.pid"
if [ -f "$PID_FILE" ]; then
    PID=$(head -n 1 "$PID_FILE" | tr -d '[:space:]')
    if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
        kill "$PID" 2>/dev/null
        count=0
        while kill -0 "$PID" 2>/dev/null && [ "${count}" -lt 10 ]; do
            sleep 1
            count=$((count + 1))
        done
        kill -9 "$PID" 2>/dev/null
    fi
    rm -f "$PID_FILE"
fi

# 根据用户选择处理数据
# wizard_data_action 环境变量由卸载向导设置
# keep: 保留数据（默认）
# delete: 删除所有数据
DATA_ACTION="${wizard_data_action:-keep}"

if [ "$DATA_ACTION" = "delete" ]; then
    echo "用户选择删除数据，正在清理..."
    rm -rf "${DATA_DIR}"
    rm -rf "${TRIM_PKGVAR}/info.log"
    rm -rf "${TRIM_PKGVAR}/app.pid"
    echo "所有应用数据已删除"
else
    echo "用户选择保留数据"
fi

echo "贴贴密笺卸载准备完成"
exit 0
