#!/bin/bash
# upgrade_callback - 升级后回调

APP_DIR="${TRIM_APPDEST}"

# 确保符号链接存在
[ -d "${APP_DIR}/app/ui" ] && [ ! -e "${APP_DIR}/ui" ] && ln -s app/ui "${APP_DIR}/ui"

# Nuitka 编译的 server 在 app/server/server
[ -f "${APP_DIR}/app/server/server" ] && chmod +x "${APP_DIR}/app/server/server"

mkdir -p "${TRIM_PKGVAR}/data" 2>/dev/null || true

exit 0
